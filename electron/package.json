{
  "name": "electron-app",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "check": "npx tsc --noEmit --project tsconfig.electron.json",
    "main:build": "npx tsc --project tsconfig.electron.json",
    "main:watch": "npx tsc --project tsconfig.electron.json --watch --preserveWatchOutput",
    "renderer:dev": "vite --config vite.config.mjs",
    "renderer:build": "vite build --config vite.config.mjs",
    "electron:dev": "wait-on http://127.0.0.1:5181 file:dist/main.js && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5181 electron . || true",
    "dev": "npm-run-all --parallel main:watch renderer:dev electron:dev",
    "build": "npm run main:build && npm run renderer:build",
    "start": "npm run build && electron .",
    "test": "vitest run --config vitest.config.mts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "core": "*",
    "outliner": "*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^1.6.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "wait-on": "^7.2.0"
  }
}